{
  "name": "frota-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "gen:sky": "node scripts/generate-sky-fleet.mjs",
    "gen:munck": "node scripts/generate-munck-fleet.mjs",
    "gen:moto": "node scripts/generate-moto-fleet.mjs",
    "gen:picape4x4": "node scripts/generate-picape4x4-fleet.mjs",
    "gen:picapeleve": "node scripts/generate-picape-leve-fleet.mjs",
    "gen:veiculosleves": "node scripts/generate-veiculos-leves-fleet.mjs",
    "gen:totalveiculos": "node scripts/generate-total-vehicles-fleet.mjs",
    "gen:ativo-placas": "node scripts/gen-fleet-ativo-placas.mjs",
    "gen:desmobilizado-placas": "node scripts/gen-fleet-desmobilizado-placas.mjs",
    "gen:catalogos": "npm run gen:totalveiculos",
    "gen:apresentacao": "node scripts/capture-apresentacao-screenshots.mjs && node scripts/generate-apresentacao-pdf.mjs",
    "gen:apresentacao:pdf": "node scripts/generate-apresentacao-pdf.mjs",
    "gen:narration": "node scripts/generate-demo-narration.mjs",
    "gen:ambient": "node scripts/generate-demo-ambient.mjs",
    "gen:demo-audio": "npm run gen:ambient && npm run gen:narration"
  },
  "dependencies": {
    "@radix-ui/react-select": "^2.2.6",
    "@supabase/supabase-js": "^2.105.4",
    "dom-to-image-more": "^3.7.2",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.14.0",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/cli": "^4.2.4",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "edge-tts-universal": "^1.4.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "playwright": "^1.60.0",
    "postcss": "^8.5.12",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^3.2.4",
    "xlsx": "^0.18.5"
  }
}
